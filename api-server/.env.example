# Ücretsiz bir anahtarı https://aistudio.google.com/apikey adresinden alın
# (Google hesabınızla giriş yapın, "Create API key" deyin — kredi kartı istemez).
# Faturalandırmayı (billing) ETKİNLEŞTİRMEYİN; böylece ücretsiz kotanın üzerine
# asla ücret yansımaz, kota dolduğunda istekler sadece hata döner.
GEMINI_API_KEY=

# İsteğe bağlı, varsayılan: gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash

PORT=8080
